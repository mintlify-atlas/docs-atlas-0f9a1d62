  "keyFeatures": [
    "Pure Go implementation with no Cgo dependencies",
    "W3C WebRTC API compatibility",
    "Full PeerConnection API with renegotiation support",
    "Bidirectional audio and video streaming",
    "Reliable and unreliable DataChannels",
    "Complete ICE, DTLS, SRTP, and SCTP implementations",
    "Hardware-accelerated encryption",
    "Cross-platform support including WebAssembly",
    "Flexible MediaEngine for codec configuration",
    "Interceptor API for RTP/RTCP processing",
    "Built-in support for simulcast and SVC"
  ],
  "publicApiSurface": [
    "PeerConnection - Main WebRTC connection interface",
    "API - Configuration API with MediaEngine and SettingEngine",
    "DataChannel - Bidirectional data channel communication",
    "RTPSender - Send RTP media streams",
    "RTPReceiver - Receive RTP media streams",
    "RTPTransceiver - Combined sender/receiver for media",
    "TrackLocal - Local media track interface",
    "TrackRemote - Remote media track interface",
    "ICEGatherer - ICE candidate gathering",
    "ICETransport - ICE transport layer",
    "DTLSTransport - DTLS encryption layer",
    "SCTPTransport - SCTP data channel transport",
    "MediaEngine - Codec and media format configuration",
    "SettingEngine - WebRTC stack configuration",
    "Configuration - PeerConnection configuration",
    "SessionDescription - SDP session descriptions",
    "Certificate - DTLS certificates"
  ]
}
